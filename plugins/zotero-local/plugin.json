{
  "name": "zotero-local",
  "version": "1.0.0",
  "description": "Modified Zotero MCP with local PDF storage, arXiv linked_url support, proxy-aware API calls",
  "author": "Sihan Liu (based on 54yyyu/zotero-mcp)",
  "mcp_servers": [
    {
      "name": "zotero",
      "command": "zotero-mcp-local",
      "env": {
        "ZOTERO_LOCAL": "true",
        "ZOTERO_API_KEY": "<your-zotero-api-key>",
        "ZOTERO_LIBRARY_ID": "<your-zotero-library-id>",
        "http_proxy": "http://127.0.0.1:7890",
        "https_proxy": "http://127.0.0.1:7890"
      }
    }
  ],
  "dependencies": ["fastmcp", "pyzotero", "requests", "markitdown", "feedparser", "unidecode", "beautifulsoup4"]
}
